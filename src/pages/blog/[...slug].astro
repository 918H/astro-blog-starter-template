---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

export const prerender = false;

const { slug } = Astro.params;
const posts = await getCollection('blog');
const staticPost = posts.find(p => p.id === slug);

let title = '文章详情';
let description = '';
let pubDate = new Date();
let heroImage = '';
let content = '';
let isStatic = !!staticPost;

if (staticPost) {
	const { Content } = await render(staticPost);
	title = staticPost.data.title;
	description = staticPost.data.description;
	pubDate = staticPost.data.pubDate;
	heroImage = staticPost.data.heroImage || '';
	content = Astro.markdownContent || '';
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.loading {
				text-align: center;
				padding: 3rem;
				color: #999;
			}
			.content-container {
				max-width: 720px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			article {
				background: white;
				padding: 2rem;
				border-radius: 8px;
				box-shadow: 0 2px 5px rgba(0,0,0,0.1);
				line-height: 1.7;
			}
			article h1 {
				margin-bottom: 0.5rem;
			}
			.meta {
				color: #666;
				margin-bottom: 2rem;
				font-size: 0.9rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{staticPost ? (
				<BlogPost {...staticPost.data}>
					<Content />
				</BlogPost>
			) : (
				<div id="kv-content">
					<div class="loading">加载中...</div>
				</div>
			)}
		</main>
		<Footer />

		<script>
			async function loadKVArticle() {
				const slug = window.location.pathname.split('/').pop().replace(/\/$/, '');
				
				try {
					const response = await fetch('/api/blog/' + slug);
					
					if (!response.ok) {
						document.getElementById('kv-content').innerHTML = '<div class="loading">文章不存在</div>';
						return;
					}

					const article = await response.json();
					document.title = article.title + ' - ' + {SITE_TITLE};

					const date = new Date(article.pubDate).toLocaleDateString('zh-CN', {
						year: 'numeric',
						month: 'long',
						day: 'numeric'
					});

					const content = await markdownToHtml(article.content);

					document.getElementById('kv-content').innerHTML = `
						<div class="content-container">
							<article class="prose">
								<h1>${escapeHtml(article.title)}</h1>
								<div class="meta">${date}</div>
								${content}
							</article>
						</div>
					`;
				} catch (err) {
					document.getElementById('kv-content').innerHTML = '<div class="loading">加载失败</div>';
				}
			}

			function escapeHtml(text) {
				const div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			async function markdownToHtml(md) {
				// 简单的 Markdown 转 HTML
				let html = md
					.replace(/^### (.*$)/gim, '<h3>$1</h3>')
					.replace(/^## (.*$)/gim, '<h2>$1</h2>')
					.replace(/^# (.*$)/gim, '<h1>$1</h1>')
					.replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
					.replace(/\*(.*)\*/gim, '<em>$1</em>')
					.replace(/^- (.*$)/gim, '<li>$1</li>')
					.replace(/```(\w*)\n([\s\S]*?)```/gim, '<pre><code class="language-$1">$2</code></pre>')
					.replace(/`(.*?)`/gim, '<code>$1</code>')
					.replace(/\n/gim, '<br>');

				return html;
			}

			if (!{staticPost ? 'true' : 'false'}) {
				loadKVArticle();
			}
		</script>
	</body>
</html>
