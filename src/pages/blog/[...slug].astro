---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

export const prerender = false;

const { slug } = Astro.params;
const posts = await getCollection('blog');
const staticPost = posts.find(p => p.id === slug);
const siteTitle = SITE_TITLE;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={staticPost?.data.title || '文章详情'} description={staticPost?.data.description || ''} />
		<style>
			.loading {
				text-align: center;
				padding: 3rem;
				color: #999;
			}
			.content-container {
				max-width: 720px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			article {
				background: white;
				padding: 2rem;
				border-radius: 8px;
				box-shadow: 0 2px 5px rgba(0,0,0,0.1);
				line-height: 1.7;
			}
			article h1 {
				margin-bottom: 0.5rem;
			}
			.meta {
				color: #666;
				margin-bottom: 2rem;
				font-size: 0.9rem;
			}
			.prose {
				font-size: 1.1rem;
			}
			.prose pre {
				background: #f5f5f5;
				padding: 1rem;
				border-radius: 4px;
				overflow-x: auto;
			}
			.prose code {
				background: #f5f5f5;
				padding: 0.2rem 0.4rem;
				border-radius: 2px;
			}
			.prose img {
				max-width: 100%;
				border-radius: 8px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{staticPost ? (
				<BlogPost {...staticPost.data}>
					<Content />
				</BlogPost>
			) : (
				<div id="kv-content">
					<div class="loading">加载中...</div>
				</div>
			)}
		</main>
		<Footer />

		<script>
			const SITE_TITLE_JSON = "{siteTitle}";
			
			async function loadKVArticle() {
				const slug = window.location.pathname.split('/').pop().replace(/\/$/, '');
				
				try {
					const response = await fetch('/api/blog/' + slug);
					
					if (!response.ok) {
						document.getElementById('kv-content').innerHTML = '<div class="loading">文章不存在</div>';
						return;
					}

					const article = await response.json();

					const date = new Date(article.pubDate).toLocaleDateString('zh-CN', {
						year: 'numeric',
						month: 'long',
						day: 'numeric'
					});

					const content = simpleMarkdownToHtml(article.content);

					document.getElementById('kv-content').innerHTML = `
						<div class="content-container">
							<article class="prose">
								<h1>${escapeHtml(article.title)}</h1>
								<div class="meta">${date}</div>
								${content}
							</article>
						</div>
					`;
				} catch (err) {
					console.error(err);
					document.getElementById('kv-content').innerHTML = '<div class="loading">加载失败</div>';
				}
			}

			function escapeHtml(text) {
				const div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			function simpleMarkdownToHtml(md) {
				let html = md
					.replace(/^### (.*$)/gim, '<h3>$1</h3>')
					.replace(/^## (.*$)/gim, '<h2>$1</h2>')
					.replace(/^# (.*$)/gim, '<h1>$1</h1>')
					.replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
					.replace(/\*(.*)\*/gim, '<em>$1</em>')
					.replace(/^- (.*$)/gim, '<li>$1</li>')
					.replace(/```(\w*)\n([\s\S]*?)```/gim, '<pre><code class="language-$1">$2</code></pre>')
					.replace(/`(.*?)`/gim, '<code>$1</code>')
					.replace(/!\[(.*?)\]\((.*?)\)/gim, '<img src="$2" alt="$1">')
					.replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" target="_blank">$1</a>')
					.replace(/\n/gim, '<br>');

				return html;
			}

			{!staticPost ? '(loadKVArticle())' : ''}
		</script>
	</body>
</html>
