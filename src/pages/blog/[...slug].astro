---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

export const prerender = false;

const { slug } = Astro.params;
const posts = await getCollection('blog');
const staticPost = posts.find(p => p.id === slug);

let kvArticle = null;
if (!staticPost) {
	try {
		const kv = Astro.locals.runtime?.env?.BLOG_STORE;
		if (kv) {
			kvArticle = await kv.get('article:' + slug, { type: 'json' });
		}
	} catch (e) {
		console.error('KV Error:', e);
	}
}

const article = staticPost || kvArticle;

if (!article) {
	Astro.response = new Response(Astro.html`
		<!doctype html>
		<html>
		<head><title>404</title></head>
		<body><h1>文章不存在</h1><a href="/blog">返回列表</a></body>
		</html>
	`, { status: 404 });
}

const title = staticPost?.data.title || kvArticle?.title || '文章详情';
const description = staticPost?.data.description || kvArticle?.description || '';
const pubDate = staticPost?.data.pubDate || (kvArticle?.pubDate ? new Date(kvArticle.pubDate) : null);

function simpleMarkdownToHtml(md) {
	if (!md) return '';
	return md
		.replace(/^### (.*$)/gim, '<h3>$1</h3>')
		.replace(/^## (.*$)/gim, '<h2>$1</h2>')
		.replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
		.replace(/\*(.*)\*/gim, '<em>$1</em>')
		.replace(/^- (.*$)/gim, '<li>$1</li>')
		.replace(/`(.*?)`/gim, '<code>$1</code>')
		.replace(/!\[(.*?)\]\((.*?)\)/gim, '<img src="$2" alt="$1">')
		.replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2">$1</a>')
		.replace(/\n/gim, '<br>');
}

let contentHtml = '';
if (staticPost) {
	const { Content } = await render(staticPost);
	contentHtml = Content;
} else if (kvArticle) {
	contentHtml = simpleMarkdownToHtml(kvArticle.content);
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main { max-width: 800px; }
			.container {
				background: white;
				border-radius: 12px;
				padding: 2rem;
				margin-top: 2rem;
				box-shadow: 0 2px 12px rgba(0,0,0,0.08);
			}
			h1 { color: #333; margin-bottom: 0.5rem; }
			.meta { color: #666; margin-bottom: 2rem; }
			.content { line-height: 1.8; color: #333; }
			.content pre { background: #f5f5f5; padding: 1rem; border-radius: 8px; overflow-x: auto; }
			.content code { background: #f5f5f5; padding: 2px 6px; border-radius: 4px; }
			.content img { max-width: 100%; }
			.back { display: inline-block; margin-bottom: 1rem; color: #666; text-decoration: none; }
			.back:hover { color: #ff6b35; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			{article && (
				<div class="container">
					<a href="/blog" class="back">← 返回列表</a>
					<h1>{title}</h1>
					<div class="meta">
						{pubDate && pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
					</div>
					<div class="content" set:html={contentHtml} />
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
