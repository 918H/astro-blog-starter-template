---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

export const prerender = false;

// 处理 Markdown 转 HTML（服务端）
function simpleMarkdownToHtml(md) {
	if (!md) return '';
	let html = md
		.replace(/^### (.*$)/gim, '<h3>$1</h3>')
		.replace(/^## (.*$)/gim, '<h2>$1</h2>')
		.replace(/^# (.*$)/gim, '<h1>$1</h1>')
		.replace(/\*\*(.*)\*\*/gim, '<strong>$1</strong>')
		.replace(/\*(.*)\*/gim, '<em>$1</em>')
		.replace(/^- (.*$)/gim, '<li>$1</li>')
		.replace(/```(\w*)\n([\s\S]*?)```/gim, '<pre><code class="language-$1">$2</code></pre>')
		.replace(/`(.*?)`/gim, '<code>$1</code>')
		.replace(/!\[(.*?)\]\((.*?)\)/gim, '<img src="$2" alt="$1">')
		.replace(/\[(.*?)\]\((.*?)\)/gim, '<a href="$2" target="_blank" rel="noopener">$1</a>')
		.replace(/^\*\s+(.*$)/gim, '<li>$1</li>')
		.replace(/\n/gim, '<br>');
	return html;
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const staticPost = posts.find(p => p.id === slug);

let kvArticle = null;
if (!staticPost) {
	const kv = Astro.locals.runtime?.env?.BLOG_STORE;
	if (kv) {
		try {
			kvArticle = await kv.get('article:' + slug, { type: 'json' });
		} catch (e) {
			console.error('Failed to load KV article:', e);
		}
	}
}

const article = staticPost || kvArticle;
if (!article) {
	Astro.response = new Response('Not Found', { status: 404 });
}

const title = article?.data?.title || article?.title || '文章不存在';
const description = article?.data?.description || article?.description || '';
const pubDate = article?.data?.pubDate || (article?.pubDate ? new Date(article.pubDate) : null);

let contentHtml = '';
if (staticPost) {
	const { Content } = await render(staticPost);
	contentHtml = Content;
} else if (kvArticle) {
	contentHtml = simpleMarkdownToHtml(kvArticle.content);
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main { max-width: 800px; }
			.article-container {
				background: white;
				border-radius: var(--border-radius);
				padding: 2.5rem;
				box-shadow: 0 2px 12px rgba(0,0,0,0.08);
				margin-top: 2rem;
			}
			.article-header {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 2px solid rgba(255, 107, 53, 0.1);
			}
			.article-header h1 {
				font-size: 2rem;
				line-height: 1.4;
				color: #333;
				margin-bottom: 1rem;
			}
			.article-meta {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				color: #666;
				font-size: 0.95rem;
			}
			.author-avatar {
				width: 32px;
				height: 32px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent), var(--accent-light));
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-weight: 700;
				font-size: 0.9rem;
			}
			.article-content {
				font-size: 1.05rem;
				line-height: 1.8;
				color: #333;
			}
			.article-content p { margin-bottom: 1.5rem; }
			.article-content h2 { font-size: 1.6rem; margin-top: 2rem; margin-bottom: 1rem; color: #333; }
			.article-content h3 { font-size: 1.3rem; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #444; }
			.article-content pre {
				background: #f8f9fa;
				padding: 1.25rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 1.5rem 0;
				border: 1px solid #e9ecef;
			}
			.article-content code {
				background: #f5f5f5;
				padding: 0.2rem 0.5rem;
				border-radius: 4px;
				font-size: 0.9em;
				color: #e83e8c;
			}
			.article-content pre code { background: transparent; padding: 0; }
			.article-content img { max-width: 100%; border-radius: 8px; margin: 1.5rem 0; }
			.article-content a { color: var(--accent); text-decoration: underline; }
			.back-link {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				color: #666;
				text-decoration: none;
				margin-bottom: 1.5rem;
				padding: 0.5rem 1rem;
				background: #f8f9fa;
				border-radius: 8px;
			}
			.back-link:hover { color: var(--accent); background: rgba(255, 107, 53, 0.1); }
			.not-found {
				text-align: center;
				padding: 4rem 2rem;
				background: white;
				border-radius: var(--border-radius);
				margin-top: 2rem;
			}
			.not-found h2 { color: #999; margin-bottom: 1rem; }
			@media (max-width: 720px) {
				.article-container { padding: 1.5rem; }
				.article-header h1 { font-size: 1.5rem; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{article ? (
				<div class="article-container">
					<a href="/blog" class="back-link">← 返回列表</a>
					<div class="article-header">
						<h1>{title}</h1>
						<div class="article-meta">
							<div style="display:flex;align-items:center;gap:0.5rem;">
								<div class="author-avatar">凳</div>
								<span>凳子大王</span>
							</div>
							{pubDate && (
								<span>{pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
							)}
						</div>
					</div>
					<div class="article-content" set:html={contentHtml} />
				</div>
			) : (
				<div class="not-found">
					<h2>📄 文章不存在</h2>
					<p>可能已经被删除或从未存在过</p>
					<a href="/blog" class="back-link" style="margin-top: 1.5rem;">← 返回文章列表</a>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
