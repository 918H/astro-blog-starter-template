---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

export const prerender = false;

const staticPosts = await getCollection('blog');
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			.empty {
				text-align: center;
				padding: 3rem;
				color: #999;
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul id="posts">
					<li class="empty">加载中...</li>
				</ul>
			</section>
		</main>
		<Footer />

		<script>
			async function loadPosts() {
				try {
					const [staticRes, kvRes] = await Promise.all([
						fetch('/static-posts.json'),
						fetch('/api/articles')
					]);

					const staticPosts = await staticRes.json().catch(() => []);
					const kvPosts = await kvRes.json().catch(() => []);

					const allPosts = [
						...staticPosts.map(p => ({
							id: p.id,
							data: p.data,
							isStatic: true
						})),
						...kvPosts.map(p => ({
							id: p.id,
							data: {
								title: p.title,
								description: p.description,
								pubDate: new Date(p.pubDate).toISOString(),
								heroImage: p.heroImage
							},
							isKV: true
						}))
					].sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

					const container = document.getElementById('posts');

					if (allPosts.length === 0) {
						container.innerHTML = '<li class="empty">暂无文章</li>';
						return;
					}

					let html = '';
					allPosts.forEach((post, index) => {
						const date = new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						});
						
						if (index === 0) {
							html += `
								<li>
									<a href="/blog/${post.id}/">
										<img width="720" height="360" src="${post.data.heroImage || '/blog-placeholder-1.jpg'}" alt="" />
										<h4 class="title">${escapeHtml(post.data.title)}</h4>
										<p class="date">${date}</p>
									</a>
								</li>
							`;
						} else {
							html += `
								<li>
									<a href="/blog/${post.id}/">
										<img width="720" height="360" src="${post.data.heroImage || '/blog-placeholder-1.jpg'}" alt="" />
										<h4 class="title">${escapeHtml(post.data.title)}</h4>
										<p class="date">${date}</p>
									</a>
								</li>
							`;
						}
					});

					container.innerHTML = html;
				} catch (err) {
					document.getElementById('posts').innerHTML = '<li class="empty">加载失败</li>';
				}
			}

			function escapeHtml(text) {
				const div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			loadPosts();
		</script>
	</body>
</html>
