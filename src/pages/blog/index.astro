---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

export const prerender = false;

const staticPosts = await getCollection('blog');

// 从 KV 读取文章
let kvPosts = [];
try {
	const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
	if (kv) {
		const keys = await kv.list();
		for (const key of (keys as any).keys || []) {
			if (key.name.startsWith('article:')) {
				const article = await kv.get(key.name, { type: 'json' });
				if (article) {
					kvPosts.push({
						id: key.name.replace('article:', ''),
						data: {
							title: article.title,
							description: article.description,
							pubDate: new Date(article.pubDate).toISOString(),
							heroImage: article.heroImage || ''
						}
					});
				}
			}
		}
	}
} catch (e) {
	console.error('Failed to load KV posts:', e);
}

const allPosts = [
	...staticPosts.map(p => ({ id: p.id, data: p.data })),
	...kvPosts
].sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { width: 960px; }
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			ul li { width: calc(50% - 1rem); }
			ul li:first-child { width: 100%; margin-bottom: 1rem; text-align: center; }
			ul li:first-child img { width: 100%; }
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
				text-decoration: none;
				transition: 0.2s;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
			}
			.date { margin: 0; color: rgb(var(--gray)); }
			ul li a:hover .title { color: rgb(var(--accent)); }
			.empty { text-align: center; padding: 3rem; color: #999; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{allPosts.length === 0 ? (
						<li class="empty">暂无文章</li>
					) : (
						allPosts.map(post => (
							<li>
								<a href={"/blog/" + post.id}>
									<img width="720" height="360" src={post.data.heroImage || '/blog-placeholder-1.jpg'} />
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										{new Date(post.data.pubDate).toLocaleDateString('zh-CN', {
											year: 'numeric',
											month: 'long',
											day: 'numeric'
										})}
									</p>
								</a>
							</li>
						))
					)}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
