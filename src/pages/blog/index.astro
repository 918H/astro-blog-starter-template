---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';

export const prerender = false;

const staticPosts = await getCollection('blog');

// 从 KV 读取文章
let kvPosts = [];
try {
	const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
	if (kv) {
		const keys = await kv.list();
		for (const key of (keys as any).keys || []) {
			if (key.name.startsWith('article:')) {
				const article = await kv.get(key.name, { type: 'json' });
				if (article) {
					kvPosts.push({
						id: key.name.replace('article:', ''),
						content: article.content,
						title: article.title,
						description: article.description,
						pubDate: new Date(article.pubDate).toISOString()
					});
				}
			}
		}
	}
} catch (e) {
	console.error('Failed to load KV posts:', e);
}

const allPosts = [
	...staticPosts.map(p => ({ 
		id: p.id, 
		content: p.compiled()?.content || '', 
		title: p.data.title,
		description: p.data.description,
		pubDate: p.data.pubDate.toISOString() 
	})),
	...kvPosts
].sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { max-width: 800px; width: 100%; }
			
			/* 页面标题 */
			.page-header {
				text-align: center;
				margin-bottom: 2rem;
				padding: 2rem 0;
			}
			.page-header h1 {
				font-size: 2rem;
				color: #333;
				margin-bottom: 0.5rem;
			}
			.page-header p {
				color: #666;
				font-size: 1rem;
			}
			
			/* 说说列表 */
			.feed-list { display: flex; flex-direction: column; gap: 1.5rem; }
			
			.feed-item {
				background: white;
				border-radius: var(--border-radius);
				padding: 1.5rem;
				box-shadow: 0 2px 8px rgba(0,0,0,0.06);
				transition: var(--transition);
				border: 1px solid rgba(0,0,0,0.04);
			}
			.feed-item:hover {
				box-shadow: 0 8px 24px rgba(0,0,0,0.12);
				transform: translateY(-3px);
				border-color: rgba(255, 107, 53, 0.2);
			}
			
			/* 头部信息 */
			.feed-header {
				display: flex;
				align-items: center;
				margin-bottom: 1rem;
				gap: 1rem;
			}
			.avatar {
				width: 44px;
				height: 44px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent), var(--accent-light));
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-weight: 700;
				font-size: 1.3rem;
				flex-shrink: 0;
				box-shadow: 0 2px 8px rgba(255, 107, 53, 0.3);
			}
			.feed-meta { flex: 1; min-width: 0; }
			.feed-author { 
				font-weight: 600; 
				color: #333;
				font-size: 1rem;
				margin-bottom: 0.25rem;
			}
			.feed-time { 
				font-size: 0.85rem; 
				color: #999;
			}
			
			/* 内容区域 */
			.feed-title {
				font-size: 1.2rem;
				font-weight: 600;
				color: #333;
				margin: 0 0 0.75rem 0;
				line-height: 1.4;
			}
			.feed-content {
				line-height: 1.8;
				color: #444;
				font-size: 1rem;
				white-space: pre-wrap;
				word-wrap: break-word;
			}
			.feed-content img { 
				max-width: 100%; 
				border-radius: 8px; 
				margin: 0.75rem 0;
				box-shadow: 0 2px 8px rgba(0,0,0,0.1);
			}
			.feed-content pre {
				background: #f8f9fa;
				padding: 1rem;
				border-radius: 8px;
				overflow-x: auto;
				font-size: 0.9rem;
				margin: 0.75rem 0;
			}
			.feed-content code {
				background: #f5f5f5;
				padding: 0.2rem 0.5rem;
				border-radius: 4px;
				font-family: Consolas, Monaco, monospace;
				font-size: 0.9em;
			}
			.feed-content pre code {
				background: transparent;
				padding: 0;
			}
			
			/* 操作按钮 */
			.feed-actions {
				margin-top: 1.25rem;
				padding-top: 1rem;
				border-top: 1px solid #f0f0f0;
				display: flex;
				gap: 1rem;
			}
			.feed-actions a {
				color: #666;
				text-decoration: none;
				font-size: 0.9rem;
				transition: var(--transition);
				padding: 0.4rem 0.8rem;
				border-radius: 6px;
				background: #f8f9fa;
			}
			.feed-actions a:hover { 
				color: var(--accent);
				background: rgba(255, 107, 53, 0.1);
			}
			
			/* 空状态 */
			.empty { 
				text-align: center; 
				padding: 4rem 2rem; 
				color: #999;
				background: white;
				border-radius: var(--border-radius);
			}
			.empty h2 { 
				margin-bottom: 0.5rem; 
				color: #ccc;
				font-size: 1.5rem;
			}
			.empty p {
				font-size: 1rem;
			}
			
			/* 悬浮按钮 */
			.admin-actions {
				position: fixed;
				bottom: 2rem;
				right: 2rem;
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
				z-index: 100;
			}
			.admin-btn {
				width: 56px;
				height: 56px;
				border-radius: 50%;
				background: linear-gradient(135deg, var(--accent), var(--accent-light));
				color: white;
				border: none;
				font-size: 1.6rem;
				cursor: pointer;
				box-shadow: 0 4px 16px rgba(255, 107, 53, 0.4);
				display: flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				transition: var(--transition);
			}
			.admin-btn:hover {
				transform: scale(1.1) rotate(15deg);
				box-shadow: 0 8px 24px rgba(255, 107, 53, 0.5);
			}
			
			/* 响应式 */
			@media (max-width: 720px) {
				.admin-actions {
					bottom: 1rem;
					right: 1rem;
				}
				.admin-btn {
					width: 50px;
					height: 50px;
					font-size: 1.4rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>📝 最近在看什么</h1>
				<p>记录学习路上的点点滴滴</p>
			</div>
			
			<div class="feed-list">
				{allPosts.length === 0 ? (
					<div class="empty">
						<h2>暂无内容</h2>
						<p>快来发布第一条说说吧</p>
					</div>
				) : (
					allPosts.map(post => {
						const date = new Date(post.pubDate);
						const timeLabel = date.toLocaleDateString('zh-CN', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
							hour: '2-digit',
							minute: '2-digit'
						});
						const hasTitle = post.title && post.title !== post.description;
						return `
						<div class="feed-item">
							<div class="feed-header">
								<div class="avatar">凳</div>
								<div class="feed-meta">
									<div class="feed-author">凳子大王</div>
									<div class="feed-time">${timeLabel}</div>
								</div>
							</div>
							${hasTitle ? `<h3 class="feed-title">${post.title}</h3>` : ''}
							<div class="feed-content">${post.content || ''}</div>
							<div class="feed-actions">
								<a href="/blog/${post.id}" target="_blank">阅读全文 →</a>
							</div>
						</div>`;
					})
				)}
			</div>
		</main>
		
		<div class="admin-actions">
			<a href="/admin/new" class="admin-btn" title="发说说">✏️</a>
		</div>
		
		<Footer />
	</body>
</html>
