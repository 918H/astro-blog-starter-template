---
export const prerender = false;

const session = Astro.cookies.get('admin')?.value;
if (session !== 'yes') {
	return Astro.redirect('/admin/login');
}

if (Astro.request.method === 'POST') {
	const data = await Astro.request.json();
	const { title, description, content } = data;
	
	if (!title || !content) {
		return new Response(JSON.stringify({ error: '标题和内容必填' }), {
			status: 400,
			headers: { 'Content-Type': 'application/json' }
		});
	}

	try {
		const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
		if (kv) {
			const id = Date.now().toString(36);
			const article = {
				title,
				description: description || title.substring(0, 50),
				content,
				pubDate: new Date().toISOString(),
				type: 'blog'
			};
			await kv.put('article:' + id, JSON.stringify(article));
			return new Response(JSON.stringify({ success: true, id }), {
				status: 201,
				headers: { 'Content-Type': 'application/json' }
			});
		}
	} catch (e: any) {
		return new Response(JSON.stringify({ error: e.message }), {
			status: 500,
			headers: { 'Content-Type': 'application/json' }
		});
	}
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>写文章</title>
		<style>
			* {
				box-sizing: border-box;
			}
			body {
				font-family: "Atkinson", -apple-system, BlinkMacSystemFont, sans-serif;
				background: #f5f7fa;
				margin: 0;
			}
			
			/* 头部导航 */
			.header {
				background: linear-gradient(135deg, #ff6b35, #ff9f43);
				color: white;
				padding: 1.25rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				box-shadow: 0 2px 12px rgba(255, 107, 53, 0.2);
			}
			.header h1 { 
				margin: 0; 
				font-size: 1.5rem; 
				font-weight: 700;
			}
			.header a {
				color: white;
				text-decoration: none;
				background: rgba(255,255,255,0.2);
				padding: 0.6rem 1.2rem;
				border-radius: 8px;
				font-weight: 500;
				transition: all 0.3s;
			}
			.header a:hover {
				background: rgba(255,255,255,0.3);
				transform: translateY(-1px);
			}
			
			/* 主体容器 */
			.container {
				max-width: 800px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			
			/* 表单卡片 */
			.card {
				background: white;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 2px 12px rgba(0,0,0,0.08);
			}
			.card-header {
				padding: 1.5rem 2rem;
				background: linear-gradient(135deg, rgba(255, 107, 53, 0.05), rgba(255, 159, 67, 0.05));
				border-bottom: 1px solid #f0f0f0;
			}
			.card-header h2 { 
				margin: 0; 
				font-size: 1.3rem; 
				color: #333;
				font-weight: 600;
			}
			
			/* 表单组 */
			.form-group {
				padding: 1.5rem 2rem;
				border-bottom: 1px solid #f0f0f0;
			}
			.form-group:last-child { 
				border-bottom: none; 
			}
			label {
				display: block;
				margin-bottom: 0.6rem;
				color: #555;
				font-weight: 600;
				font-size: 0.95rem;
			}
			.required {
				color: #dc3545;
				margin-left: 0.25rem;
			}
			input[type="text"] {
				width: 100%;
				padding: 0.9rem 1.1rem;
				border: 2px solid #e9ecef;
				border-radius: 12px;
				font-size: 1rem;
				font-family: inherit;
				transition: all 0.3s;
				background: #f8f9fa;
			}
			input[type="text"]:focus {
				outline: none;
				border-color: #ff6b35;
				background: white;
				box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
			}
			input[type="text"]::placeholder {
				color: #adb5bd;
			}
			textarea {
				width: 100%;
				padding: 0.9rem 1.1rem;
				border: 2px solid #e9ecef;
				border-radius: 12px;
				font-size: 1rem;
				font-family: inherit;
				min-height: 350px;
				resize: vertical;
				line-height: 1.8;
				transition: all 0.3s;
				background: #f8f9fa;
			}
			textarea:focus {
				outline: none;
				border-color: #ff6b35;
				background: white;
				box-shadow: 0 0 0 4px rgba(255, 107, 53, 0.1);
			}
			textarea::placeholder {
				color: #adb5bd;
			}
			
			/* 格式提示 */
			.format-tips {
				background: linear-gradient(135deg, rgba(255, 107, 53, 0.05), rgba(255, 159, 67, 0.05));
				border: 1px solid rgba(255, 107, 53, 0.2);
				border-radius: 12px;
				padding: 1.25rem;
				margin-top: 1rem;
			}
			.format-tips h4 {
				margin: 0 0 0.75rem;
				color: #ff6b35;
				font-size: 0.95rem;
				font-weight: 600;
			}
			.format-tips ul {
				margin: 0;
				padding-left: 1.25rem;
				color: #666;
				font-size: 0.9rem;
				line-height: 1.8;
			}
			.format-tips code {
				background: rgba(255, 107, 53, 0.1);
				padding: 0.15rem 0.4rem;
				border-radius: 4px;
				color: #ff6b35;
				font-family: Consolas, Monaco, monospace;
				font-size: 0.85em;
			}
			
			/* 操作按钮 */
			.actions {
				padding: 1.5rem 2rem;
				background: #f8f9fa;
				display: flex;
				gap: 1rem;
				justify-content: flex-end;
				border-top: 1px solid #f0f0f0;
			}
			.btn {
				padding: 0.85rem 2rem;
				border-radius: 12px;
				font-size: 1rem;
				cursor: pointer;
				border: none;
				font-weight: 600;
				text-decoration: none;
				transition: all 0.3s;
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
			}
			.btn-primary {
				background: linear-gradient(135deg, #ff6b35, #ff9f43);
				color: white;
				box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
			}
			.btn-primary:hover {
				box-shadow: 0 6px 16px rgba(255, 107, 53, 0.4);
				transform: translateY(-2px);
			}
			.btn-primary:disabled {
				opacity: 0.6;
				cursor: not-allowed;
				transform: none;
			}
			.btn-secondary {
				background: #f0f0f0;
				color: #333;
			}
			.btn-secondary:hover { 
				background: #e0e0e0;
				transform: translateY(-1px);
			}
			
			/* 消息提示 */
			.message {
				padding: 1.25rem 2rem;
				display: none;
				font-weight: 500;
			}
			.message.success { 
				background: linear-gradient(135deg, #d4edda, #c3e6cb);
				color: #155724; 
				display: block;
				border-bottom: 1px solid #c3e6cb;
			}
			.message.error { 
				background: linear-gradient(135deg, #f8d7da, #f5c6cb);
				color: #721c24;
				display: block;
				border-bottom: 1px solid #f5c6cb;
			}
			
			/* 字符统计 */
			.char-count {
				text-align: right;
				font-size: 0.85rem;
				color: #999;
				margin-top: 0.5rem;
			}
			
			/* 响应式 */
			@media (max-width: 720px) {
				.header {
					padding: 1rem;
				}
				.header h1 {
					font-size: 1.2rem;
				}
				.card-header,
				.form-group,
				.actions {
					padding-left: 1.25rem;
					padding-right: 1.25rem;
				}
				.actions {
					flex-direction: column-reverse;
				}
				.btn {
					width: 100%;
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<div class="header">
			<h1>✏️ 写文章</h1>
			<a href="/admin">返回管理</a>
		</div>

		<div class="container">
			<div class="card">
				<div id="message" class="message"></div>
				
				<div class="card-header">
					<h2>填写文章信息</h2>
				</div>
				
				<div class="form-group">
					<label>
						标题 <span class="required">*</span>
					</label>
					<input 
						type="text" 
						id="title" 
						placeholder="输入文章标题" 
						maxlength="100"
					/>
				</div>
				
				<div class="form-group">
					<label>描述</label>
					<input 
						type="text" 
						id="description" 
						placeholder="简短描述（可选，不填则自动生成）" 
						maxlength="200"
					/>
				</div>
				
				<div class="form-group">
					<label>
						内容 <span class="required">*</span>
					</label>
					<textarea 
						id="content" 
						placeholder="写点什么吧...

支持简单的 Markdown 格式：
# 标题
**加粗** *斜体*
- 列表项
`代码`"
					></textarea>
					<div class="char-count">
						<span id="charCount">0</span> 字符
					</div>
					<div class="format-tips">
						<h4>📝 支持的格式</h4>
						<ul>
							<li><code># 标题</code> - 一级标题</li>
							<li><code>## 标题</code> - 二级标题</li>
							<li><code>**加粗**</code> - <strong>加粗文本</strong></li>
							<li><code>*斜体*</code> - <em>斜体文本</em></li>
							<li><code>- 列表</code> - 无序列表</li>
							<li><code>`代码`</code> - 行内代码</li>
							<li><code>``` 代码块 ```</code> - 代码块</li>
							<li><code>[链接](url)</code> - 超链接</li>
							<li><code>![图片](url)</code> - 图片</li>
						</ul>
					</div>
				</div>
				
				<div class="actions">
					<a href="/admin" class="btn btn-secondary">取消</a>
					<button type="button" id="publishBtn" class="btn btn-primary">
						🚀 发布文章
					</button>
				</div>
			</div>
		</div>

		<script>
			const titleInput = document.getElementById('title');
			const descInput = document.getElementById('description');
			const contentTextarea = document.getElementById('content');
			const charCount = document.getElementById('charCount');
			const publishBtn = document.getElementById('publishBtn');
			const message = document.getElementById('message');

			// 字符统计
			contentTextarea.addEventListener('input', () => {
				charCount.textContent = contentTextarea.value.length;
			});

			publishBtn.addEventListener('click', async () => {
				const title = titleInput.value.trim();
				const description = descInput.value.trim();
				const content = contentTextarea.value.trim();

				if (!title) {
					showMessage('error', '⚠️ 标题不能为空');
					titleInput.focus();
					return;
				}
				if (!content) {
					showMessage('error', '⚠️ 内容不能为空');
					contentTextarea.focus();
					return;
				}

				publishBtn.disabled = true;
				publishBtn.textContent = '发布中...';

				try {
					const res = await fetch('/api/create', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ title, description, content })
					});

					const result = await res.json();

					if (res.ok) {
						showMessage('success', '✅ 发布成功！3 秒后跳转...');
						setTimeout(() => {
							window.location.href = '/admin';
						}, 3000);
					} else {
						showMessage('error', '⚠️ 发布失败：' + result.error);
						publishBtn.disabled = false;
						publishBtn.textContent = '🚀 发布文章';
					}
				} catch (e) {
					showMessage('error', '⚠️ 网络错误：' + e.message);
					publishBtn.disabled = false;
					publishBtn.textContent = '🚀 发布文章';
				}
			});

			function showMessage(type, text) {
				message.className = 'message ' + type;
				message.textContent = text;
				message.style.display = 'block';
			}
		</script>
	</body>
</html>
