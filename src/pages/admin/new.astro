---
// 新建文章页面
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>新建文章 - 凳子大王的技术博客</title>
		<style>
			* {
				box-sizing: border-box;
			}
			body {
				font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
				background: #f5f5f5;
				margin: 0;
			}
			.header {
				background: #ff6b35;
				color: white;
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.header h1 {
				margin: 0;
				font-size: 1.5rem;
			}
			.header a {
				color: white;
				text-decoration: none;
				background: rgba(255,255,255,0.2);
				padding: 0.5rem 1rem;
				border-radius: 4px;
			}
			.container {
				max-width: 800px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			.form-card {
				background: white;
				padding: 2rem;
				border-radius: 8px;
				box-shadow: 0 2px 5px rgba(0,0,0,0.1);
			}
			.form-group {
				margin-bottom: 1.5rem;
			}
			label {
				display: block;
				margin-bottom: 0.5rem;
				color: #666;
				font-weight: 500;
			}
			input[type="text"],
			input[type="date"],
			textarea {
				width: 100%;
				padding: 0.75rem;
				border: 1px solid #ddd;
				border-radius: 4px;
				font-size: 1rem;
				font-family: inherit;
			}
			input[type="text"]:focus,
			input[type="date"]:focus,
			textarea:focus {
				outline: none;
				border-color: #ff6b35;
			}
			textarea {
				min-height: 400px;
				resize: vertical;
				font-family: 'Courier New', monospace;
				line-height: 1.6;
			}
			.form-actions {
				display: flex;
				gap: 1rem;
				justify-content: flex-end;
			}
			.btn {
				padding: 0.75rem 1.5rem;
				border-radius: 4px;
				text-decoration: none;
				cursor: pointer;
				border: none;
				font-size: 1rem;
				transition: all 0.2s;
			}
			.btn-primary {
				background: #ff6b35;
				color: white;
			}
			.btn-primary:hover {
				background: #e85d2a;
			}
			.btn-secondary {
				background: #f0f0f0;
				color: #333;
			}
			.btn-secondary:hover {
				background: #e0e0e0;
			}
			.message {
				padding: 1rem;
				border-radius: 4px;
				margin-bottom: 1rem;
				display: none;
			}
			.message.success {
				background: #d4edda;
				color: #155724;
				display: block;
			}
			.message.error {
				background: #f8d7da;
				color: #721c24;
				display: block;
			}
			.tip {
				font-size: 0.85rem;
				color: #999;
				margin-top: 0.5rem;
			}
		</style>
	</head>
	<body>
		<div class="header">
			<h1>新建文章</h1>
			<div>
				<a href="/admin/dashboard">返回列表</a>
			</div>
		</div>

		<div class="container">
			<div class="form-card">
				<div class="message" id="message"></div>
				
				<form id="articleForm">
					<div class="form-group">
						<label for="title">标题 *</label>
						<input type="text" id="title" name="title" required placeholder="输入文章标题" />
					</div>

					<div class="form-group">
						<label for="description">描述 *</label>
						<input type="text" id="description" name="description" required placeholder="简短描述，用于列表页展示" />
						<div class="tip">建议控制在 50-100 字以内</div>
					</div>

					<div class="form-group">
						<label for="pubDate">发布日期 *</label>
						<input type="date" id="pubDate" name="pubDate" required />
					</div>

					<div class="form-group">
						<label for="heroImage">封面图片（可选）</label>
						<input type="text" id="heroImage" name="heroImage" placeholder="/blog-placeholder-1.jpg" />
						<div class="tip">图片路径，例如：/blog-placeholder-1.jpg</div>
					</div>

					<div class="form-group">
						<label for="content">文章内容 (Markdown 格式) *</label>
						<textarea id="content" name="content" required placeholder="# 文章标题

这里是文章内容，支持 Markdown 格式...

## 小标题

- 列表项 1
- 列表项 2

```javascript
// 代码块
console.log('Hello');
```

"></textarea>
					</div>

					<div class="form-actions">
						<a href="/admin/dashboard" class="btn btn-secondary">取消</a>
						<button type="submit" class="btn btn-primary">发布文章</button>
					</div>
				</form>
			</div>
		</div>

		<script>
			const form = document.getElementById('articleForm');
			const messageDiv = document.getElementById('message');

			document.getElementById('pubDate').valueAsDate = new Date();

			form.addEventListener('submit', async (e) => {
				e.preventDefault();

				const formData = {
					title: document.getElementById('title').value,
					description: document.getElementById('description').value,
					pubDate: document.getElementById('pubDate').value,
					heroImage: document.getElementById('heroImage').value,
					content: document.getElementById('content').value
				};

				try {
					const response = await fetch('/api/articles', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(formData)
					});

					const data = await response.json();

					if (response.ok) {
						messageDiv.className = 'message success';
						messageDiv.textContent = '文章已发布！3 秒后跳转到列表...';
						setTimeout(() => {
							window.location.href = '/admin/dashboard';
						}, 3000);
					} else {
						messageDiv.className = 'message error';
						messageDiv.textContent = data.error || '发布失败';
					}
				} catch (err) {
					messageDiv.className = 'message error';
					messageDiv.textContent = '网络错误：' + err.message;
				}
			});
		</script>
	</body>
</html>
