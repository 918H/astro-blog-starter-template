---
export const prerender = false;

const session = Astro.cookies.get('admin_session')?.value;
if (session !== 'authenticated') {
	return Astro.redirect('/admin/login');
}

// 处理 POST 请求 - 创建说说
if (Astro.request.method === 'POST') {
	const data = await Astro.request.json();
	const { content } = data;
	
	if (!content || content.trim().length === 0) {
		return new Response(JSON.stringify({ error: '内容不能为空' }), {
			status: 400,
			headers: { 'Content-Type': 'application/json' }
		});
	}

	try {
		const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
		if (kv) {
			const id = Date.now().toString(36);
			const article = {
				title: '说说 #' + id,
				description: content.substring(0, 50) + (content.length > 50 ? '...' : ''),
				content: content,
				pubDate: new Date().toISOString(),
				updatedDate: new Date().toISOString(),
				type: 'shuoshuo'
			};
			await kv.put('article:' + id, JSON.stringify(article));
			return new Response(JSON.stringify({ success: true, id }), {
				status: 201,
				headers: { 'Content-Type': 'application/json' }
			});
		}
	} catch (e: any) {
		return new Response(JSON.stringify({ error: e.message }), {
			status: 500,
			headers: { 'Content-Type': 'application/json' }
		});
	}
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>发说说</title>
		<style>
			* { box-sizing: border-box; }
			body {
				font-family: -apple-system, BlinkMacSystemFont, sans-serif;
				background: #f0f2f5;
				margin: 0;
			}
			.header {
				background: #4e7dff;
				color: white;
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				box-shadow: 0 2px 8px rgba(0,0,0,0.1);
			}
			.header h1 { margin: 0; font-size: 1.5rem; }
			.header a {
				color: white;
				text-decoration: none;
				background: rgba(255,255,255,0.2);
				padding: 0.5rem 1rem;
				border-radius: 4px;
				margin-left: 0.5rem;
			}
			.container {
				max-width: 600px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			.post-card {
				background: white;
				border-radius: 12px;
				box-shadow: 0 2px 12px rgba(0,0,0,0.08);
				overflow: hidden;
			}
			.post-header {
				padding: 1rem 1.5rem;
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				color: white;
			}
			.post-header h2 {
				margin: 0;
				font-size: 1.2rem;
				font-weight: 600;
			}
			.post-input {
				width: 100%;
				min-height: 200px;
				padding: 1.5rem;
				border: none;
				resize: vertical;
				font-family: inherit;
				font-size: 1rem;
				line-height: 1.6;
			}
			.post-input:focus {
				outline: none;
				background: #fafafa;
			}
			.post-footer {
				padding: 1rem 1.5rem;
				background: #fafafa;
				border-top: 1px solid #eee;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.char-count {
				color: #999;
				font-size: 0.9rem;
			}
			.btn {
				padding: 0.75rem 2rem;
				border-radius: 25px;
				font-size: 1rem;
				cursor: pointer;
				border: none;
				font-weight: 600;
				transition: all 0.3s;
			}
			.btn-primary {
				background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
				color: white;
			}
			.btn-primary:hover {
				transform: scale(1.05);
				box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
			}
			.btn-primary:disabled {
				background: #ccc;
				cursor: not-allowed;
				transform: none;
				box-shadow: none;
			}
			.message {
				padding: 1rem 1.5rem;
				display: none;
				font-size: 0.9rem;
			}
			.message.success {
				background: #d4edda;
				color: #155724;
				display: block;
				border-bottom: 1px solid #c3e6cb;
			}
			.message.error {
				background: #f8d7da;
				color: #721c24;
				display: block;
				border-bottom: 1px solid #f5c6cb;
			}
		</style>
	</head>
	<body>
		<div class="header">
			<h1>✨ 发说说</h1>
			<div>
				<a href="/blog">首页</a>
			</div>
		</div>

		<div class="container">
			<div class="post-card">
				<div class="post-header">
					<h2>此刻在想什么？</h2>
				</div>
				
				<div id="message" class="message"></div>
				
				<textarea 
					id="content" 
					class="post-input" 
					placeholder="说点什么吧...
					
想说的、记录的、分享的，都可以在这里～"
					maxlength="10000"
				></textarea>
				
				<div class="post-footer">
					<span class="char-count"><span id="charCount">0</span> / 10000</span>
					<button type="button" id="publishBtn" class="btn btn-primary">发布</button>
				</div>
			</div>
		</div>

		<script>
			const contentInput = document.getElementById('content');
			const charCount = document.getElementById('charCount');
			const publishBtn = document.getElementById('publishBtn');
			const messageDiv = document.getElementById('message');

			contentInput.addEventListener('input', () => {
				charCount.textContent = contentInput.value.length;
			});

			publishBtn.addEventListener('click', async () => {
				const content = contentInput.value.trim();
				
				if (!content) {
					showMessage('error', '说点什么吧～');
					return;
				}

				publishBtn.disabled = true;
				publishBtn.textContent = '发布中...';

				try {
					const response = await fetch('/api/create', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ content })
					});

					const result = await response.json();

					if (response.ok) {
						showMessage('success', '✨ 发布成功！3 秒后跳转...');
						setTimeout(() => {
							window.location.href = '/blog';
						}, 3000);
					} else {
						showMessage('error', '发布失败：' + result.error);
						publishBtn.disabled = false;
						publishBtn.textContent = '发布';
					}
				} catch (e) {
					showMessage('error', '网络错误：' + e.message);
					publishBtn.disabled = false;
					publishBtn.textContent = '发布';
				}
			});

			function showMessage(type, text) {
				messageDiv.className = 'message ' + type;
				messageDiv.textContent = text;
			}
		</script>
	</body>
</html>
