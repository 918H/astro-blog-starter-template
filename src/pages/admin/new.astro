---
export const prerender = false;

const session = Astro.cookies.get('admin')?.value;
if (session !== 'yes') {
	return Astro.redirect('/admin/login');
}

if (Astro.request.method === 'POST') {
	const data = await Astro.request.json();
	const { title, description, content } = data;
	
	if (!title || !content) {
		return new Response(JSON.stringify({ error: '标题和内容必填' }), {
			status: 400,
			headers: { 'Content-Type': 'application/json' }
		});
	}

	try {
		const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
		if (kv) {
			const id = Date.now().toString(36);
			const article = {
				title,
				description: description || title.substring(0, 50),
				content,
				pubDate: new Date().toISOString(),
				type: 'blog'
			};
			await kv.put('article:' + id, JSON.stringify(article));
			return new Response(JSON.stringify({ success: true, id }), {
				status: 201,
				headers: { 'Content-Type': 'application/json' }
			});
		}
	} catch (e: any) {
		return new Response(JSON.stringify({ error: e.message }), {
			status: 500,
			headers: { 'Content-Type': 'application/json' }
		});
	}
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<title>写文章</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				background: #f5f5f5;
				margin: 0;
			}
			.header {
				background: #4e7dff;
				color: white;
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
			}
			.header h1 { margin: 0; font-size: 1.5rem; }
			.header a {
				color: white;
				text-decoration: none;
				background: rgba(255,255,255,0.2);
				padding: 0.5rem 1rem;
				border-radius: 4px;
				margin-left: 0.5rem;
			}
			.container {
				max-width: 800px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			.card {
				background: white;
				border-radius: 12px;
				overflow: hidden;
			}
			.card-header {
				padding: 1.5rem;
				background: #4e7dff;
				color: white;
			}
			.card-header h2 { margin: 0; font-size: 1.2rem; }
			.form-group {
				padding: 1.5rem;
				border-bottom: 1px solid #eee;
			}
			.form-group:last-child { border-bottom: none; }
			label {
				display: block;
				margin-bottom: 0.5rem;
				color: #666;
				font-weight: 500;
			}
			input[type="text"],
			textarea {
				width: 100%;
				padding: 0.75rem;
				border: 1px solid #ddd;
				border-radius: 8px;
				font-size: 1rem;
				font-family: inherit;
				box-sizing: border-box;
			}
			textarea {
				min-height: 300px;
				resize: vertical;
				line-height: 1.6;
			}
			input:focus,
			textarea:focus {
				outline: none;
				border-color: #4e7dff;
			}
			.actions {
				padding: 1.5rem;
				background: #fafafa;
				display: flex;
				gap: 1rem;
				justify-content: flex-end;
			}
			.btn {
				padding: 0.75rem 2rem;
				border-radius: 8px;
				font-size: 1rem;
				cursor: pointer;
				border: none;
				font-weight: 600;
			}
			.btn-primary {
				background: #4e7dff;
				color: white;
			}
			.btn-primary:hover { background: #3d6be5; }
			.btn-secondary {
				background: #f0f0f0;
				color: #333;
			}
			.btn-secondary:hover { background: #e0e0e0; }
			.message {
				padding: 1rem;
				display: none;
			}
			.message.success { background: #d4edda; color: #155724; display: block; }
			.message.error { background: #f8d7da; color: #721c24; display: block; }
		</style>
	</head>
	<body>
		<div class="header">
			<h1>✏️ 写文章</h1>
			<a href="/admin">返回</a>
		</div>

		<div class="container">
			<div class="card">
				<div class="card-header">
					<h2>填写文章信息</h2>
				</div>
				
				<div id="message" class="message"></div>
				
				<div class="form-group">
					<label>标题 *</label>
					<input type="text" id="title" placeholder="输入文章标题" />
				</div>
				
				<div class="form-group">
					<label>描述</label>
					<input type="text" id="description" placeholder="简短描述（可选）" />
				</div>
				
				<div class="form-group">
					<label>内容 *</label>
					<textarea id="content" placeholder="写点什么吧...&#10;&#10;支持简单的格式：&#10;**加粗** *斜体*&#10;# 标题&#10;- 列表项"></textarea>
				</div>
				
				<div class="actions">
					<a href="/admin" class="btn btn-secondary">取消</a>
					<button type="button" id="publishBtn" class="btn btn-primary">发布</button>
				</div>
			</div>
		</div>

		<script>
			const publishBtn = document.getElementById('publishBtn');
			const message = document.getElementById('message');

			publishBtn.addEventListener('click', async () => {
				const title = document.getElementById('title').value.trim();
				const description = document.getElementById('description').value.trim();
				const content = document.getElementById('content').value.trim();

				if (!title) {
					showMessage('error', '标题不能为空');
					return;
				}
				if (!content) {
					showMessage('error', '内容不能为空');
					return;
				}

				publishBtn.disabled = true;
				publishBtn.textContent = '发布中...';

				try {
					const res = await fetch('/api/create', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ title, description, content })
					});

					const result = await res.json();

					if (res.ok) {
						showMessage('success', '✅ 发布成功！3 秒后跳转...');
						setTimeout(() => {
							window.location.href = '/admin';
						}, 3000);
					} else {
						showMessage('error', '发布失败：' + result.error);
						publishBtn.disabled = false;
						publishBtn.textContent = '发布';
					}
				} catch (e) {
					showMessage('error', '网络错误：' + e.message);
					publishBtn.disabled = false;
					publishBtn.textContent = '发布';
				}
			});

			function showMessage(type, text) {
				message.className = 'message ' + type;
				message.textContent = text;
			}
		</script>
	</body>
</html>
