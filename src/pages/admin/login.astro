---
export const prerender = false;

if (Astro.request.method === 'POST') {
	const data = await Astro.request.formData();
	const password = data.get('password');
	
	if (password === 'dzdwnb666') {
		Astro.cookies.set('admin', 'yes', {
			path: '/',
			maxAge: 60 * 60 * 24 * 7,
			httpOnly: true,
			sameSite: 'lax'
		});
		return Astro.redirect('/admin');
	} else {
		Astro.cookies.set('admin_error', '密码错误', {
			maxAge: 60,
			httpOnly: false
		});
	}
}

const errorMsg = Astro.cookies.get('admin_error')?.value;
if (errorMsg) {
	Astro.cookies.delete('admin_error');
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<title>管理员登录</title>
		<style>
			body {
				font-family: system-ui, sans-serif;
				background: #f5f5f5;
				margin: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
			}
			.login-card {
				background: white;
				border-radius: 12px;
				box-shadow: 0 4px 20px rgba(0,0,0,0.1);
				padding: 2.5rem;
				width: 100%;
				max-width: 400px;
			}
			.login-card h1 {
				margin: 0 0 0.5rem;
				color: #333;
				font-size: 1.5rem;
				text-align: center;
			}
			.login-card p {
				text-align: center;
				color: #666;
				margin-bottom: 2rem;
			}
			.form-group {
				margin-bottom: 1.5rem;
			}
			label {
				display: block;
				margin-bottom: 0.5rem;
				color: #666;
				font-weight: 500;
			}
			input[type="password"] {
				width: 100%;
				padding: 0.75rem;
				border: 1px solid #ddd;
				border-radius: 8px;
				font-size: 1rem;
				box-sizing: border-box;
			}
			input:focus {
				outline: none;
				border-color: #4e7dff;
			}
			.btn {
				width: 100%;
				padding: 0.75rem;
				background: #4e7dff;
				color: white;
				border: none;
				border-radius: 8px;
				font-size: 1rem;
				font-weight: 600;
				cursor: pointer;
			}
			.btn:hover {
				background: #3d6be5;
			}
			.error {
				background: #fee;
				color: #c00;
				padding: 0.75rem;
				border-radius: 8px;
				margin-bottom: 1.5rem;
				text-align: center;
			}
			.back-link {
				text-align: center;
				margin-top: 1.5rem;
			}
			.back-link a {
				color: #666;
				text-decoration: none;
			}
			.back-link a:hover {
				color: #4e7dff;
			}
		</style>
	</head>
	<body>
		<div class="login-card">
			<h1>🔐 管理员登录</h1>
			<p>输入验证码访问后台</p>
			
			{errorMsg ? <div class="error">{errorMsg}</div> : null}
			
			<form method="post">
				<div class="form-group">
					<label>验证码</label>
					<input type="password" name="password" placeholder="请输入验证码" autofocus />
				</div>
				<button type="submit" class="btn">登录</button>
			</form>
			
			<div class="back-link">
				<a href="/">← 返回首页</a>
			</div>
		</div>
	</body>
</html>
