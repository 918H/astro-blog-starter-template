---
export const prerender = false;

const session = Astro.cookies.get('admin')?.value;
if (session !== 'yes') {
	return Astro.redirect('/admin/login');
}

let articles = [];
try {
	const kv = (Astro.locals.runtime as any)?.env?.BLOG_STORE;
	if (kv) {
		const keys = await kv.list();
		for (const key of (keys as any).keys || []) {
			if (key.name.startsWith('article:')) {
				const article = await kv.get(key.name, { type: 'json' });
				if (article) {
					articles.push({
						id: key.name.replace('article:', ''),
						...article
					});
				}
			}
		}
	}
	articles.sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());
} catch (e) {
	console.error('Failed to load articles:', e);
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>文章管理</title>
		<style>
			* {
				box-sizing: border-box;
			}
			body {
				font-family: "Atkinson", -apple-system, BlinkMacSystemFont, sans-serif;
				background: #f5f7fa;
				margin: 0;
			}
			
			/* 头部导航 */
			.header {
				background: linear-gradient(135deg, #ff6b35, #ff9f43);
				color: white;
				padding: 1.25rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				box-shadow: 0 2px 12px rgba(255, 107, 53, 0.2);
				position: sticky;
				top: 0;
				z-index: 100;
			}
			.header h1 { 
				margin: 0; 
				font-size: 1.5rem; 
				font-weight: 700;
			}
			.header nav {
				display: flex;
				gap: 0.75rem;
			}
			.header a {
				color: white;
				text-decoration: none;
				background: rgba(255,255,255,0.2);
				padding: 0.6rem 1.2rem;
				border-radius: 8px;
				font-weight: 500;
				transition: all 0.3s;
			}
			.header a:hover {
				background: rgba(255,255,255,0.3);
				transform: translateY(-1px);
			}
			
			/* 主体容器 */
			.container {
				max-width: 900px;
				margin: 2rem auto;
				padding: 0 1rem;
			}
			
			/* 统计信息 */
			.stats {
				background: white;
				border-radius: 12px;
				padding: 1.5rem;
				margin-bottom: 1.5rem;
				box-shadow: 0 2px 8px rgba(0,0,0,0.06);
				display: flex;
				align-items: center;
				justify-content: space-between;
			}
			.stats-info {
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.stats-icon {
				width: 48px;
				height: 48px;
				background: linear-gradient(135deg, #ff6b35, #ff9f43);
				border-radius: 12px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.5rem;
			}
			.stats h2 {
				margin: 0 0 0.25rem;
				font-size: 1.8rem;
				color: #333;
			}
			.stats p {
				margin: 0;
				color: #666;
				font-size: 0.95rem;
			}
			
			/* 文章列表 */
			.article-list {
				background: white;
				border-radius: 12px;
				overflow: hidden;
				box-shadow: 0 2px 8px rgba(0,0,0,0.06);
			}
			.article-item {
				padding: 1.5rem;
				border-bottom: 1px solid #f0f0f0;
				display: flex;
				justify-content: space-between;
				align-items: center;
				transition: all 0.3s;
			}
			.article-item:last-child { 
				border-bottom: none; 
			}
			.article-item:hover {
				background: #fafbfc;
			}
			.article-info {
				flex: 1;
				min-width: 0;
			}
			.article-info h3 {
				margin: 0 0 0.5rem;
				color: #333;
				font-size: 1.1rem;
				font-weight: 600;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.article-info p { 
				margin: 0 0 0.5rem;
				color: #666; 
				font-size: 0.85rem;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.article-meta {
				display: flex;
				gap: 1.5rem;
				font-size: 0.9rem;
				color: #999;
			}
			.article-time { 
				color: #999; 
			}
			
			/* 操作按钮 */
			.actions { 
				display: flex; 
				gap: 0.5rem;
				flex-shrink: 0;
			}
			.btn {
				padding: 0.55rem 1.1rem;
				border-radius: 8px;
				text-decoration: none;
				font-size: 0.9rem;
				cursor: pointer;
				border: none;
				font-weight: 600;
				transition: all 0.3s;
			}
			.btn-view { 
				background: rgba(255, 107, 53, 0.1); 
				color: #ff6b35; 
			}
			.btn-view:hover { 
				background: rgba(255, 107, 53, 0.2);
				transform: translateY(-1px);
			}
			.btn-delete { 
				background: rgba(220, 53, 69, 0.1); 
				color: #dc3545; 
			}
			.btn-delete:hover { 
				background: rgba(220, 53, 69, 0.2);
				transform: translateY(-1px);
			}
			
			/* 空状态 */
			.empty { 
				text-align: center; 
				padding: 4rem 2rem;
			}
			.empty-icon {
				font-size: 4rem;
				margin-bottom: 1rem;
			}
			.empty h2 { 
				margin: 0 0 0.5rem; 
				color: #999; 
				font-size: 1.5rem;
			}
			.empty p { 
				color: #bbb;
				margin: 0 0 1.5rem;
				font-size: 1rem;
			}
			.btn-primary {
				background: linear-gradient(135deg, #ff6b35, #ff9f43);
				color: white;
				box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
			}
			.btn-primary:hover {
				box-shadow: 0 6px 16px rgba(255, 107, 53, 0.4);
				transform: translateY(-2px);
			}
			
			/* 响应式 */
			@media (max-width: 720px) {
				.header {
					padding: 1rem;
				}
				.header h1 {
					font-size: 1.2rem;
				}
				.header nav {
					gap: 0.5rem;
				}
				.header a {
					padding: 0.5rem 0.8rem;
					font-size: 0.85rem;
				}
				.article-item {
					flex-direction: column;
					align-items: flex-start;
					gap: 1rem;
				}
				.actions {
					width: 100%;
					justify-content: flex-end;
				}
			}
		</style>
	</head>
	<body>
		<div class="header">
			<h1>📋 文章管理</h1>
			<nav>
				<a href="/">首页</a>
				<a href="/admin/new">写文章</a>
				<a href="/admin/logout">退出</a>
			</nav>
		</div>

		<div class="container">
			<div class="stats">
				<div class="stats-info">
					<div class="stats-icon">📝</div>
					<div>
						<h2>{articles.length}</h2>
						<p>篇文章</p>
					</div>
				</div>
			</div>
			
			<div class="article-list">
				{articles.length === 0 ? (
					<div class="empty">
						<div class="empty-icon">📭</div>
						<h2>暂无文章</h2>
						<p>点击"写文章"创建第一篇</p>
						<a href="/admin/new" class="btn btn-primary">写文章</a>
					</div>
				) : (
					articles.map(article => (
						<div class="article-item">
							<div class="article-info">
								<h3>{article.title}</h3>
								<p>{article.description}</p>
								<div class="article-meta">
									<span class="article-time">
										{new Date(article.pubDate).toLocaleString('zh-CN', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
											hour: '2-digit',
											minute: '2-digit'
										})}
									</span>
								</div>
							</div>
							<div class="actions">
								<a href={"/blog/" + article.id} class="btn btn-view" target="_blank">查看</a>
								<button class="btn btn-delete" onclick="del('{article.id}')">删除</button>
							</div>
						</div>
					))
				)}
			</div>
		</div>

		<script>
			async function del(id) {
				if (!confirm('确定删除这篇文章吗？')) return;
				try {
					const res = await fetch('/api/delete', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ id })
					});
					if (res.ok) {
						location.reload();
					} else {
						alert('删除失败');
					}
				} catch (e) {
					alert('删除失败：' + e.message);
				}
			}
		</script>
	</body>
</html>
