---
export const prerender = false;

export async function onRequest({ request, env, cookies }) {
	// 验证登录
	const session = cookies.get('admin')?.value;
	if (session !== 'yes') {
		return new Response(JSON.stringify({ error: '未登录' }), {
			status: 401,
			headers: { 'Content-Type': 'application/json' }
		});
	}

	// 只处理 POST 请求
	if (request.method !== 'POST') {
		return new Response(JSON.stringify({ error: 'Method not allowed' }), {
			status: 405,
			headers: { 'Content-Type': 'application/json' }
		});
	}

	try {
		// 解析 JSON
		let data;
		try {
			data = await request.json();
		} catch (e) {
			return new Response(JSON.stringify({ error: '无效的 JSON 数据' }), {
				status: 400,
				headers: { 'Content-Type': 'application/json' }
			});
		}

		const { title, description, content } = data;

		// 验证必填字段
		if (!title || !title.trim()) {
			return new Response(JSON.stringify({ error: '标题不能为空' }), {
				status: 400,
				headers: { 'Content-Type': 'application/json' }
			});
		}
		if (!content || !content.trim()) {
			return new Response(JSON.stringify({ error: '内容不能为空' }), {
				status: 400,
				headers: { 'Content-Type': 'application/json' }
			});
		}

		// 检查 KV 存储
		if (!env.BLOG_STORE) {
			console.error('BLOG_STORE KV namespace is not configured');
			return new Response(JSON.stringify({ error: '服务器配置错误：KV 存储未配置' }), {
				status: 500,
				headers: { 'Content-Type': 'application/json' }
			});
		}

		// 生成 ID 并保存
		const id = Date.now().toString(36);
		const article = {
			title: title.trim(),
			description: description?.trim() || title.substring(0, 50),
			content: content.trim(),
			pubDate: new Date().toISOString(),
			type: 'blog'
		};

		await env.BLOG_STORE.put('article:' + id, JSON.stringify(article));
		console.log('Article created:', id);

		return new Response(JSON.stringify({ success: true, id }), {
			status: 201,
			headers: { 'Content-Type': 'application/json' }
		});

	} catch (e) {
		console.error('Create API Error:', e);
		return new Response(JSON.stringify({ error: '服务器错误：' + e.message }), {
			status: 500,
			headers: { 'Content-Type': 'application/json' }
		});
	}
}
---
