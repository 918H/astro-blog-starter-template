---
export const prerender = false;

const session = Astro.cookies.get('admin')?.value;

if (Astro.request.method === 'POST' && session === 'yes') {
	try {
		const body = await Astro.request.json();
		const { title, description, content } = body;
		
		if (!title || !content) {
			return Astro.json({ error: '标题和内容必填' }, 400);
		}
		
		const kv = Astro.locals.runtime?.env?.BLOG_STORE;
		if (!kv) {
			return Astro.json({ error: 'KV 存储未配置' }, 500);
		}
		
		const id = Date.now().toString(36);
		const article = {
			title,
			description: description || title.substring(0, 50),
			content,
			pubDate: new Date().toISOString(),
			type: 'blog'
		};
		
		await kv.put('article:' + id, JSON.stringify(article));
		return Astro.json({ success: true, id }, 201);
		
	} catch (e) {
		console.error('Create Error:', e);
		return Astro.json({ error: e.message }, 500);
	}
}

if (session !== 'yes') {
	return Astro.json({ error: '未登录' }, 401);
}

return Astro.json({ error: 'Method not allowed' }, 405);
---
