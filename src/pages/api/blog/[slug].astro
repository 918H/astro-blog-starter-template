---
export const prerender = false;

const { slug } = Astro.params;
if (!slug) {
	return Astro.json({ error: '文章不存在' }, 404);
}

const kv = Astro.locals.runtime?.env?.BLOG_STORE;
if (!kv) {
	return Astro.json({ error: 'KV 存储未配置' }, 500);
}

try {
	const article = await kv.get('article:' + slug, { type: 'json' });
	
	if (!article) {
		return Astro.json({ error: '文章不存在' }, 404);
	}
	
	return Astro.json(article, 200);
	
} catch (e) {
	console.error('Blog API Error:', e);
	return Astro.json({ error: e.message }, 500);
}
